<section class="shop-the-look">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-title {{ section.settings.heading_align }} {{ section.settings.heading_align_mob }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="look-grid">
      {% for block in section.blocks %}
        <div class="look-item" {{ block.shopify_attributes }}>
          {%- comment -%} ✅ Image fallback logic added {%- endcomment -%}
          {% if block.settings.product != blank %}
            <img
              src="{{ block.settings.product.featured_image | image_url: width: 433 }}"
              alt="{{ block.settings.product.title }}"
              class="look-image"
            >
          {% elsif block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 433 }}"
              alt="look image"
              class="look-image"
            >
          {% endif %}

          {% if block.settings.product != blank %}
            <button
              class="hotspot"
              data-product-handle="{{ block.settings.product.handle }}"
              style="top: {{ block.settings.top }}%; left: {{ block.settings.left }}%;"
            >
              {% render 'hotspot-icon' %}
            </button>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<div id="quick-view-modal" class="quick-view-modal"></div>

<style>
  .shop-the-look {
    padding: 9rem 0 5.1rem 0;
  }

  .section-title {
    margin: 0;
    margin-bottom: 30px;
    font-size: 3.6rem;
    letter-spacing: 0%;
    line-height: 120%;
  }

  .left-head {
    text-align: left;
  }
  .center-head {
    text-align: center;
  }
  .right-head {
    text-align: right;
  }

  .look-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .look-item {
    position: relative;
    min-height: 444px;
  }

  .look-image {
    width: 100%;
    display: block;
    height: 100%;
    object-fit: cover;
  }

  .hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    text-align: center;
    cursor: pointer;
    background: none;
    outline: 0;
    border: 0;
  }

  /* .hotspot:hover {
      background: #444;
    } */

  .quick-view-modal {
    display: none;
    position: fixed;
    z-index: 9999;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);

    justify-content: center;
    align-items: center;
  }

  .quick-view-content {
    background: #fff;
    max-width: 311px;
    margin: 0 auto;
    padding: 3.6rem 1.5rem 2.5rem 1.5rem;
    position: relative;
  }

  .quick-view-info {
    flex: 1;
    font-family: 'Jost', sans-serif;
    font-weight: normal;
  }

  @media (max-width: 990px) {
    .look-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .look-item {
      position: relative;
      min-height: 186px;
    }
  }
  @media (max-width: 768px) {
    .look-grid {
      gap: 0.4rem;
    }
    .section-title {
      font-size: 2.4rem;
      margin-bottom: 20px;
    }
    .left-head-mob {
      text-align: left;
    }
    .right-head-mob {
      text-align: right;
    }
    .center-head-mob {
      text-align: center;
    }
  }
</style>
<script>
  console.log('----------------------this.colorPicker');

  class VariantPicker extends HTMLElement {
    constructor() {
      super();
      this.selectedOptions = {};
    }
    connectedCallback() {
      this.productData = this.getProductData();

      this.handleColor();
      this.handleSizeDropdown();
      this.handleAddToCart(); // 👈 ADD THIS
      this.initDefault();
      this.updateVariant();
    }

    getProductData() {
      const el = document.getElementById('product-data');
      if (!el) {
        console.error('Product-data not found');
        return null;
      }
      return JSON.parse(el.textContent);
    }

    initDefault() {
      const active = this.querySelector('.variant-btn.active');
      // custom-select-label
      if (active) {
        this.selectedOptions[active.dataset.option] = active.dataset.value;
      }
    }

    handleColor() {
      this.colorPicker = this.querySelector('.segmented-control');
      if (!this.colorPicker) return;

      this.colorPicker.addEventListener('click', (e) => {
        const btn = e.target.closest('.variant-btn');
        if (!btn) return;

        this.querySelectorAll('.variant-btn').forEach((b) => b.classList.remove('active'));

        btn.classList.add('active');
        console.log('===> Selected : ', btn.dataset.value);
        this.selectedOptions['option1'] = btn.dataset.value;
        this.updateVariant();
      });
    }
    handleSizeDropdown() {
      const wrapper = this.querySelector('.custom-select-wrapper');
      if (!wrapper) return;

      const trigger = wrapper.querySelector('.custom-select-trigger');
      const label = wrapper.querySelector('.custom-select-label');
      const options = wrapper.querySelectorAll('.custom-select-option');

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();

        wrapper.classList.toggle('open');
      });

      options.forEach((option) => {
        option.addEventListener('click', () => {
          options.forEach((o) => o.classList.remove('selected'));

          option.classList.add('selected');

          label.textContent = option.dataset.value;

          wrapper.classList.remove('open');

          console.log('===> Size Selected:', option.dataset.value);
          this.selectedOptions['option2'] = option.dataset.value;

          this.updateVariant();
        });
      });

      document.addEventListener('click', (e) => {
        if (!this.contains(e.target)) {
          wrapper.classList.remove('open');
        }
      });
    }
    getCurrentVariantData() {
      if (!this.productData) return null;

      const variant = this.productData.find((v) => {
        return Object.values(this.selectedOptions).every((value, index) => {
          return v.options[index] && value && v.options[index].toLowerCase() === value.toLowerCase();
        });
      });

      console.log('Matched Variant:', variant);

      return variant || null;
    }

    updateVariant() {
      const variant = this.getCurrentVariantData();
      const input = document.getElementById('selected-variant-id');

      if (variant) {
        input.value = variant.id;
        console.log('✅ Variant:', variant);
      } else {
        input.value = '';
        console.log('❌ No matching variant');
      }
    }

    handleAddToCart() {
      const form = this.closest('form');
      if (!form) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const variantId = form.querySelector('#selected-variant-id')?.value;

        if (!variantId) {
          alert('Please select size and color');
          return;
        }

        const btn = form.querySelector('.add-to-cart');
        btn.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: variantId,
            quantity: 1,
          }),
        })
          .then(() => fetch('/cart.js')) // 👈 GET UPDATED CART
          .then((res) => res.json())
          .then((cartData) => {
            console.log('🛒 Cart:', cartData);

            // ✅ PUBLISH EVENT (Shopify Dawn system)
            if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
              publish(PUB_SUB_EVENTS.cartUpdate, {
                source: 'variant-picker',
                cartData: cartData,
                variantId: variantId,
              });
            }

            btn.disabled = false;
          })
          .catch((err) => {
            console.error(err);
            btn.disabled = false;
          });
      });
    }
  }

  customElements.define('variant-picker', VariantPicker);
</script>

<script>
  document.querySelectorAll('.hotspot').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const handle = btn.dataset.productHandle;

      const res = await fetch(`/products/${handle}?sections=quick-view`);
      const obj = await res.json();

      console.log('-----------', obj);
      const modal = document.getElementById('quick-view-modal');

      modal.innerHTML = obj['quick-view'];

      modal.style.display = 'flex';

      modal.querySelector('.close-modal')?.addEventListener('click', () => {
        modal.style.display = 'none';
        modal.innerHTML = '';
      });
    });
  });
</script>

{% schema %}
{
  "name": "Shop the Look",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Look"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment for desktop",
      "options": [
        { "value": "left-head", "label": "Left" },
        { "value": "center-head", "label": "Center" },
        { "value": "right-head", "label": "Right" }
      ],
      "default": "left-head"
    },
    {
      "type": "select",
      "id": "heading_align_mob",
      "label": "Heading alignment for mobile",
      "options": [
        { "value": "left-head-mob", "label": "Left" },
        { "value": "center-head-mob", "label": "Center" },
        { "value": "right-head-mob", "label": "Right" }
      ],
      "default": "left-head-mob"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "top",
          "label": "Hotspot vertical position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "left",
          "label": "Hotspot horizontal position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Shop the Look"
    }
  ]
}
{% endschema %}
